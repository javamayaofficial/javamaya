# ============================================================
# JAVAMAYA .env.example
# Diisi otomatis oleh installer 4 langkah.
# Kredensial provider juga bisa diisi via Admin > Integrations
# (disimpan encrypted di DB dan MENANG atas nilai .env).
# ============================================================

APP_NAME=Javamaya
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tokoanda.com
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=javamaya
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=43200
CACHE_STORE=database
QUEUE_CONNECTION=database   # VPS boleh: redis
FILESYSTEM_DISK=local

MAIL_FROM_ADDRESS=halo@tokoanda.com
MAIL_FROM_NAME="${APP_NAME}"

# ---------- WhatsApp Providers (aktif dipilih di Settings) ----------
WA_PROVIDER=fonnte
FONNTE_TOKEN=
ONESENDER_TOKEN=
STARSENDER_TOKEN=
KIRIMDEV_TOKEN=

# ---------- Email Providers ----------
EMAIL_PROVIDER=mailketing
MAILKETING_API_KEY=
DRIPSENDER_API_KEY=

# ---------- Payment Gateways (toggle + sandbox via Admin > Payment Gateways) ----------
DUITKU_MERCHANT_CODE=
DUITKU_API_KEY=
DUITKU_SANDBOX_MODE=true

XENDIT_API_KEY=
XENDIT_WEBHOOK_TOKEN=
XENDIT_SANDBOX_MODE=true

MOOTA_TOKEN=
MOOTA_WEBHOOK_SECRET=

# Manual Transfer + QRIS Manual (fallback selalu tersedia)
MANUAL_TRANSFER_BANK_NAME=
MANUAL_TRANSFER_ACCOUNT_NUMBER=
MANUAL_TRANSFER_ACCOUNT_HOLDER=
QRIS_IMAGE_URL=

# ---------- OAuth ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# ---------- Meta CAPI (Tahap 2) ----------
META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# ---------- Pajak (default; editable via Admin > Tax Settings, DB menang) ----------
TAX_PPN_DEFAULT_PERCENT=11
TAX_PPN_INCLUSIVE=true

# ---------- Backup ----------
BACKUP_RETENTION=7
# S3-compatible (Tahap 3): Wasabi / DO Spaces / Contabo
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_ENDPOINT=

# ---------- Cron ----------
CRON_SECRET=   # digenerate installer; regenerate di Admin > API Keys & Webhook URL

# ---------- Vendor Javamaya (Auto-Update + License) ----------
JAVAMAYA_UPDATE_URL=https://license.javamaya.id/api/update
JAVAMAYA_LICENSE_URL=https://license.javamaya.id/api/license
JAVAMAYA_CHANNEL=stable
# Public key Ed25519 milik license server vendor (hex 64 chars).
# Wajib diisi dengan public key yang berpasangan dengan LICENSE_SIGNING_SECRET di server lisensi.
JAVAMAYA_LICENSE_PUBKEY=
JAVAMAYA_LICENSE_KEY=
