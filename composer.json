{
    "name": "javamaya/javamaya",
    "description": "Javamaya - Self-Hosted Digital Product & Online Class Platform untuk Kreator dan Bisnis Indonesia",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "ext-sodium": "*",
        "ext-gd": "*",
        "ext-zip": "*",
        "laravel/framework": "^11.0",
        "laravel/sanctum": "^4.0",
        "laravel/socialite": "^5.14",
        "filament/filament": "^3.2",
        "barryvdh/laravel-dompdf": "^3.0",
        "pragmarx/google2fa-laravel": "^2.2",
        "bacon/bacon-qr-code": "^3.0",
        "league/commonmark": "^2.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "laravel/pint": "^1.17"
    },
    "autoload": {
        "psr-4": { "App\\": "app/", "Database\\Seeders\\": "database/seeders/" },
        "files": ["app/Support/helpers.php"]
    },
    "config": { "optimize-autoloader": true, "preferred-install": "dist" },
    "minimum-stability": "stable",
    "prefer-stable": true
}
